# 服务端口
PORT=3000

# ==================== AI 模型配置 ====================
# 选择一个提供商：siliconflow 或 bailian
AI_PROVIDER=siliconflow

# 硅基流动 API 配置
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# 阿里云百炼 API 配置
# 支持模型：qwen3.5-plus, qwen3-max-2026-01-23, qwen3-coder-next, qwen3-coder-plus,
#          MiniMax-M2.5, glm-5, glm-4.7, kimi-k2.5
BAILIAN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_MODEL=qwen3.5-plus

# 微信测试号配置
WECHAT_APP_ID=wxxxxxxxxxxx
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WECHAT_TOKEN=your_custom_token_here

# TickTick / Dida365 OpenAPI 配置（可选）
TICKTICK_BASE_URL=https://api.dida365.com/open/v1
TICKTICK_ACCESS_TOKEN=
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=
TICKTICK_REFRESH_TOKEN=
TICKTICK_OAUTH_BASE_URL=https://dida365.com

# AI 助理身份
ASSISTANT_NAME=小助理

# 目录配置（可选，默认值如下）
# CONFIG_DIR=./config
# DATA_DIR=./data

# Skill 配置加密主密钥（重要！）
# 用于加密通过 /set 指令保存的 Skill API Key 等敏感配置
# 设置任意随机字符串即可，例如：openssl rand -hex 32
# ⚠️ 不设置则每次重启使用随机密钥，已保存的配置将无法解密
# CONFIG_MASTER_KEY=your_random_secret_here
